# Server Configuration
PORT=5001
NODE_ENV=development

# Security
JWT_SECRET=your_jwt_secret_here

# Firebase (Must be a valid JSON string of the service account key)
FIREBASE_SERVICE_ACCOUNT={"type": "service_account", "project_id": "placeholder"}

# GitHub OAuth Integration
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:5173/github/callback

# Local/dev SMTP (app running without Docker; MailHog exposed on localhost)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=Mini Trello <no-reply@skipli.local>
