# Backend production runtime configuration.
# Copy this file to backend/.env.production on the production server and fill in real values.

NODE_ENV=production
PORT=5001

JWT_SECRET=replace-with-a-strong-production-secret
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"replace-me"}

GITHUB_CLIENT_ID=replace-with-github-oauth-client-id
GITHUB_CLIENT_SECRET=replace-with-github-oauth-client-secret
GITHUB_CALLBACK_URL=http://your-production-host-or-domain:80/github/callback

# Local/dev SMTP (MailHog in Docker Compose)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=Mini Trello <no-reply@skipli.local>
